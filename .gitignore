# Track only the SketchUp work added this session; ignore the rest of the large tree
# (Portal has its own repo; proposals/DXF/data are not for this repo).
/*
!.gitignore
!sketchup_study/
!sketchup_generator/

# within the tracked modules, skip generated/binary artifacts
sketchup_generator/out/
sketchup_study/geom_out/batch.log
**/__pycache__/
*.pyc
*.skb
*.skp
!sketchup_generator/seed_template.skp   # keep the bundled seed for the orchestrator
!sketchup_generator/parts/*.skp          # real components placed by the generator
!sketchup_study/components_lib/*.skp     # the extracted real-parts library
